rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is the administrator
    function isAdmin() {
      return request.auth != null && (request.auth.token.email == 'mariuscm@gmail.com' || request.auth.uid == '7qKfZzd3cnbsNFifwYKCyg6CCYS2');
    }

    // Check if the match has started yet by reading the match date
    function matchNotStarted(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.date > request.time;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /guesses/{guessId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && (isAdmin() || (request.auth.uid == request.resource.data.userId && matchNotStarted(request.resource.data.matchId)));
      allow update: if request.auth != null 
                    && (isAdmin() || (request.auth.uid == resource.data.userId && matchNotStarted(resource.data.matchId)));
      allow delete: if request.auth != null 
                    && (isAdmin() || (resource.data.userId == request.auth.uid && matchNotStarted(resource.data.matchId)));
    }

    match /settings/{settingsId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
